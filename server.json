{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Musaraf-M/sentinal-mcp",
  "description": "Redis health, BullMQ queue monitoring, memory analysis, and slow query diagnostics",
  "repository": {
    "url": "https://github.com/Musaraf-M/sentinal",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@md-musaraf/sentinal-mcp",
      "version": "1.0.5",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Redis connection URL",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "REDIS_URL"
        }
      ]
    }
  ]
}
